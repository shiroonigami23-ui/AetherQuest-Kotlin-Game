<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:endColor="#34d399"
                android:startColor="#14b8a6" />
        </shape>
    </item>
    <item android:bottom="7dp" android:left="7dp" android:right="7dp" android:top="7dp">
        <shape android:shape="oval">
            <solid android:color="#082f49" />
            <stroke android:width="2dp" android:color="#a7f3d0" />
        </shape>
    </item>
</layer-list>
