<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="315"
                android:endColor="#334155"
                android:startColor="#6366f1" />
        </shape>
    </item>
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="300"
                android:endColor="#111827"
                android:startColor="#1f2937" />
            <stroke android:width="1dp" android:color="#c4b5fd" />
        </shape>
    </item>
    <item android:left="17dp" android:top="20dp" android:right="17dp" android:bottom="17dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#eab676"
                android:startColor="#f7d4a2" />
        </shape>
    </item>
</layer-list>
